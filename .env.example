NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/mytrip
ADMIN_PASSWORD=change-me
UPLOAD_DIR=./uploads

# Optional frontend override. Leave empty when the API and frontend share the same host.
VITE_API_URL=

# Optional if the app runs behind a different frontend origin in development.
CORS_ORIGIN=http://localhost:5173

# Optional but recommended for outgoing links in email notifications.
APP_URL=http://localhost:5173

# Brevo email delivery
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=myTrip
BREVO_REPLY_TO_EMAIL=
PROBLEM_REPORT_EMAIL=

# Cloudinary branding/media library integration
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Online payments
PAYMENT_CURRENCY=HUF
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
